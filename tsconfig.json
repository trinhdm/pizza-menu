{
  "compilerOptions": {
    "target": "es2023",
    "lib": [
      "dom",
      "dom.iterable",
      "es2023"
    ],
    "allowImportingTsExtensions": true,
    "allowJs": false,
    "esModuleInterop": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    ".next/dev/types/**/*.ts",
    ".next/types/**/*.ts",
    "*.config.*",
	// "**/*.d.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts"
  ],
  "sourceMap": true
}
